{
    "model_name": "facebook/convnext-small-224",
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "eta_min": 1e-06,
    "epochs": 30,
    "batch_size": 32,
    "effective_batch_size": 64,
    "accumulation_steps": 2,
    "optimizer": "AdamW",
    "scheduler": "CosineAnnealing",
    "loss": "CrossEntropyLoss+MixUp+ECA",
    "mixup_alpha": 0.4,
    "augmentation": "HFlip+VFlip+Rotation15+ColorJitter+RandomErasing",
    "sampler": "WeightedRandomSampler",
    "attention": "ECA",
    "dropout_rate": 0.0,
    "feature_flags": {
        "use_cbam": false,
        "use_eca": true,
        "use_ordinal_loss": false,
        "use_focal_loss": false,
        "use_mixup": true,
        "use_cutmix": false,
        "use_three_stage": false,
        "use_warmup": false,
        "use_discriminative_lr": false
    }
}