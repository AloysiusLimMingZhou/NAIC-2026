{
    "model_name": "facebook/convnext-small-224",
    "learning_rate": 0.0001,
    "lr_early": 1e-06,
    "lr_middle": 1e-05,
    "weight_decay": 0.01,
    "eta_min": 1e-06,
    "warmup_epochs": 3,
    "epochs": 30,
    "batch_size": 32,
    "optimizer": "AdamW",
    "scheduler": "LinearWarmup+CosineAnnealing",
    "loss": "CrossEntropyLoss+MixUp+ECA",
    "focal_gamma": 2.0,
    "focal_weight": 0.7,
    "ordinal_weight": 0.3,
    "mixup_alpha": 0.4,
    "augmentation": "HFlip+VFlip+Rotation15+ColorJitter+RandomErasing",
    "sampler": "WeightedRandomSampler",
    "attention": "CBAM",
    "feature_flags": {
        "use_cbam": false,
        "use_eca": true,
        "use_ordinal_loss": false,
        "use_focal_loss": false,
        "use_mixup": true,
        "use_three_stage": false,
        "use_warmup": false,
        "use_discriminative_lr": false
    },
    "stage1_epochs": 5,
    "stage2_lr": 1e-05,
    "stage3_lr": 5e-06
}