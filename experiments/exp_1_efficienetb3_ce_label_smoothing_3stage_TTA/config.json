{
    "model_name": "google/efficientnet-b3",
    "learning_rate": 0.001,
    "lr_early": 1e-05,
    "lr_middle": 0.0001,
    "weight_decay": 0.0001,
    "eta_min": 1e-06,
    "warmup_epochs": 3,
    "epochs": 20,
    "batch_size": 32,
    "optimizer": "AdamW",
    "scheduler": "CosineAnnealingLR",
    "focal_gamma": 2.0,
    "focal_weight": 0.7,
    "ordinal_weight": 0.3,
    "label_smoothing": 0.1,
    "mixup_alpha": 0.4,
    "stage1_epochs": 3,
    "stage2_lr": 0.0001,
    "stage3_lr": 1e-06,
    "stage2_duration": 3,
    "feature_flags": {
        "use_label_smoothing": true,
        "use_focal_loss": false,
        "use_ordinal_loss": false,
        "use_mixup": false,
        "use_three_stage": true,
        "use_warmup": false,
        "use_discriminative_lr": false,
        "use_tta": true,
        "use_cbam": false,
        "use_eca": false
    },
    "augmentation_pipeline": [
        "Resize: Resize(size=(300, 300), interpolation=bilinear, max_size=None, antialias=True)",
        "RandomHorizontalFlip: RandomHorizontalFlip(p=0.5)",
        "RandomVerticalFlip: RandomVerticalFlip(p=0.5)",
        "RandomRotation: RandomRotation(degrees=[-15.0, 15.0], interpolation=nearest, expand=False, fill=0)",
        "ColorJitter: ColorJitter(brightness=(0.8, 1.2), contrast=(0.8, 1.2), saturation=(0.8, 1.2), hue=None)",
        "ToTensor: ToTensor()",
        "Normalize: Normalize(mean=(0.485, 0.456, 0.406), std=(0.47853944, 0.4732864, 0.47434163))",
        "RandomErasing: RandomErasing(p=0.3, scale=(0.02, 0.15), ratio=(0.3, 3.3), value=0, inplace=False)"
    ],
    "loss": "CE+LabelSmoothing(eps=0.1)",
    "attention": "None",
    "schedule": "CosineAnnealing + 3StageUnfreeze"
}