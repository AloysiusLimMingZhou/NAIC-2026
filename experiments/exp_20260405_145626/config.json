{
    "model": "microsoft/swinv2-base-patch4-window8-256",
    "learning_rate": 5e-05,
    "weight_decay": 0.0001,
    "epochs": 20,
    "batch_size": 16,
    "optimizer": "AdamW",
    "scheduler": "CosineAnnealingLR",
    "loss": "FocalLoss",
    "focal_gamma": 2.0,
    "label_smoothing": 0.1,
    "k_folds": 5,
    "augmentation": "HFlip+VFlip+Rotation15+ColorJitter",
    "sampler": "WeightedRandomSampler"
}